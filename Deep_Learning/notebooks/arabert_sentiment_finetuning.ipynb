        "# FINAL TEST EVALUATION\n",
        "# Load best checkpoint and evaluate on held-out test set\n",
        "# ─────────────────────────────────────────────────────────────────\n",
        "\n",
        "# Load best model (prefer Stage 3, then Stage 2, then Stage 1)\n",
        "best_ckpt_path = stage3_ckpt_path if 'stage3_ckpt_path' in globals() else (stage2_ckpt_path if 'stage2_ckpt_path' in globals() else CONFIG['save_path'])\n",
        "checkpoint = torch.load(best_ckpt_path, map_location=device)\n",
        "model.load_state_dict(checkpoint['model_state_dict'])\n",
        "print(f\"Loaded model from epoch {checkpoint['epoch']} with Val F1: {checkpoint['val_f1']:.4f}\")\n",
        "\n",
        "# Evaluate on test set\n",
        "model.eval()\n",
        "all_preds  = []\n",
        "all_labels = []\n",
        "all_probs  = []\n",
        "\n",
        "with torch.no_grad():\n",
        "    for batch in tqdm(test_loader, desc='Testing'):\n",
        "        input_ids      = batch['input_ids'].to(device)\n",
        "        attention_mask = batch['attention_mask'].to(device)\n",
        "        token_type_ids = batch['token_type_ids'].to(device)\n",
        "        labels         = batch['labels'].to(device)\n",
        "\n",
        "        outputs = model(\n",
        "            input_ids      = input_ids,\n",
        "            attention_mask = attention_mask,\n",
        "            token_type_ids = token_type_ids\n",
        "        )\n",
        "        logits = outputs.logits\n",
        "        probs  = torch.softmax(logits, dim=-1)   # Get probabilities\n",
        "        preds  = torch.argmax(logits, dim=-1)\n",
        "\n",
        "        all_preds.extend(preds.cpu().numpy())\n",
        "        all_labels.extend(labels.cpu().numpy())\n",
        "        all_probs.extend(probs.cpu().numpy())\n",
        "\n",
        "# ─────────────────────────────────────────────────────────────────\n",
