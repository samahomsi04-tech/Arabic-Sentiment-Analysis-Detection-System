      "source": [
        "# ─────────────────────────────────────────────────────────────────\n",
        "# STAGE 3: SELECTIVE ATTENTION\n",
        "# ─────────────────────────────────────────────────────────────────\n",
        "\n",
        "import math\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "\n",
        "class SelectiveBertSelfAttention(nn.Module):\n",
        "    def __init__(self, base_self_attention, keep_ratio=0.5):\n",
        "        super().__init__()\n",
        "        self.keep_ratio = keep_ratio\n",
        "\n",
        "        self.query = base_self_attention.query\n",
        "        self.key = base_self_attention.key\n",
        "        self.value = base_self_attention.value\n",
        "        self.dropout = base_self_attention.dropout\n",
        "\n",
        "        self.num_attention_heads = base_self_attention.num_attention_heads\n",
        "        self.attention_head_size = base_self_attention.attention_head_size\n",
        "        self.all_head_size = base_self_attention.all_head_size\n",
        "        self.is_decoder = getattr(base_self_attention, 'is_decoder', False)\n",
        "        self.position_embedding_type = getattr(base_self_attention, 'position_embedding_type', 'absolute')\n",
        "\n",
        "    def transpose_for_scores(self, x):\n",
        "        new_x_shape = x.size()[:-1] + (self.num_attention_heads, self.attention_head_size)\n",
        "        x = x.view(*new_x_shape)\n",
        "        return x.permute(0, 2, 1, 3)\n",
        "\n",
        "    def forward(\n",
        "        self,\n",
        "        hidden_states,\n",
        "        attention_mask=None,\n",
        "        head_mask=None,\n",
        "        encoder_hidden_states=None,\n",
        "        past_key_value=None,\n",
        "        output_attentions=False,\n",
        "        cache_position=None,\n",
        "        **kwargs\n",
        "    ):\n",
        "        mixed_query_layer = self.query(hidden_states)\n",
        "\n",
        "        is_cross_attention = encoder_hidden_states is not None\n",
        "        source_states = encoder_hidden_states if is_cross_attention else hidden_states\n",
        "\n",
        "        key_layer = self.transpose_for_scores(self.key(source_states))\n",
        "        value_layer = self.transpose_for_scores(self.value(source_states))\n",
        "        query_layer = self.transpose_for_scores(mixed_query_layer)\n",
        "\n",
        "        attention_scores = torch.matmul(query_layer, key_layer.transpose(-1, -2))\n",
        "        attention_scores = attention_scores / math.sqrt(self.attention_head_size)\n",
        "\n",
        "        if attention_mask is not None:\n",
        "            attention_scores = attention_scores + attention_mask\n",
        "\n",
        "        seq_len = attention_scores.size(-1)\n",
        "        k_keep = max(1, int(seq_len * self.keep_ratio))\n",
        "        topk_idx = torch.topk(attention_scores, k=k_keep, dim=-1).indices\n",
        "\n",
        "        min_value = torch.finfo(attention_scores.dtype).min\n",
        "        masked_scores = torch.full_like(attention_scores, min_value)\n",
        "        masked_scores.scatter_(-1, topk_idx, attention_scores.gather(-1, topk_idx))\n",
        "\n",
        "        attention_probs = torch.softmax(masked_scores, dim=-1)\n",
        "        attention_probs = self.dropout(attention_probs)\n",
        "\n",
        "        if head_mask is not None:\n",
        "            attention_probs = attention_probs * head_mask\n",
        "\n",
        "        context_layer = torch.matmul(attention_probs, value_layer)\n",
        "        context_layer = context_layer.permute(0, 2, 1, 3).contiguous()\n",
        "        new_context_shape = context_layer.size()[:-2] + (self.all_head_size,)\n",
        "        context_layer = context_layer.view(*new_context_shape)\n",
        "\n",
        "        if output_attentions:\n",
        "            return context_layer, attention_probs\n",
        "        else:\n",
        "            return context_layer, None\n",
        "\n",
        "\n",
        "def apply_selective_attention(model, layer_indices, keep_ratio=0.5):\n",
        "    for layer_idx in layer_indices:\n",
        "        old_self_attn = model.bert.encoder.layer[layer_idx].attention.self\n",
        "        model.bert.encoder.layer[layer_idx].attention.self = SelectiveBertSelfAttention(\n",
        "            old_self_attn,\n",
        "            keep_ratio=keep_ratio\n",
        "        )\n",
        "    print(f\"Selective attention applied to layers: {layer_indices}\")\n",
        "    print(f\"Keep ratio per query: {keep_ratio:.2f}\")\n",
        "\n",
        "\n",
        "# Load best checkpoint from Stage 2 if available, else Stage 1\n",
        "stage3_base_ckpt = stage2_ckpt_path if 'stage2_ckpt_path' in globals() else CONFIG['save_path']\n",
        "checkpoint = torch.load(stage3_base_ckpt, map_location=device)\n",
        "model.load_state_dict(checkpoint['model_state_dict'])\n",
        "print(f\"Loaded base checkpoint for Stage 3 from epoch {checkpoint['epoch']} (Val F1: {checkpoint['val_f1']:.4f})\")\n",
        "\n",
        "# Make all layers trainable before Stage 3\n",
        "freeze_arabert_layers(\n",
        "    model,\n",
        "    freeze_embeddings=False,\n",
        "    num_frozen_layers=0\n",
        ")\n",
        "\n",
        "# Apply selective attention\n",
        "STAGE3_SELECTIVE_LAYERS = list(range(len(model.bert.encoder.layer)))\n",
        "STAGE3_KEEP_RATIO = 0.50\n",
        "\n",
        "apply_selective_attention(\n",
        "    model,\n",
        "    layer_indices=STAGE3_SELECTIVE_LAYERS,\n",
        "    keep_ratio=STAGE3_KEEP_RATIO\n",
        ")\n",
        "\n",
        "# Stage 3 optimizer / scheduler\n",
        "STAGE3_LR = 3e-6\n",
        "STAGE3_EPOCHS = 10\n",
        "stage3_ckpt_path = 'best_arabert_stage3_selective.pt'\n",
        "\n",
        "optimizer_s3 = Adam(\n",
        "    [p for p in model.parameters() if p.requires_grad],\n",
        "    lr=STAGE3_LR,\n",
        "    weight_decay=CONFIG['weight_decay'],\n",
        "    #eps=1e-8\n",
        ")\n",
        "\n",
        "total_steps_s3  = len(train_loader) * STAGE3_EPOCHS\n",
        "warmup_steps_s3 = int(total_steps_s3 * 0.05)\n",
        "\n",
        "scheduler_s3 = get_linear_schedule_with_warmup(\n",
        "    optimizer_s3,\n",
        "    num_warmup_steps=warmup_steps_s3,\n",
        "    num_training_steps=total_steps_s3\n",
        ")\n",
        "\n",
        "early_stopper_s3 = EarlyStopping(patience=2, min_delta=0.001, mode='max')\n",
        "\n",
        "best_val_f1_s3 = checkpoint['val_f1']\n",
        "history_stage3 = []\n",
        "\n",
        "print(f\"\\nStage 3 training: LR={STAGE3_LR}, up to {STAGE3_EPOCHS} epochs\\n\")\n",
        "\n",
        "for epoch in range(1, STAGE3_EPOCHS + 1):\n",
        "    print(f\"Stage 3 — Epoch {epoch}/{STAGE3_EPOCHS}\")\n",
        "    print('─' * 50)\n",
        "\n",
        "    train_loss, train_metrics = train_one_epoch(\n",
        "        model, train_loader, optimizer_s3, scheduler_s3, loss_fn, device\n",
        "    )\n",
        "    val_loss, val_metrics = evaluate(model, val_loader, loss_fn, device)\n",
        "\n",
        "    print(f\"  Train → Loss: {train_loss:.4f}  F1: {train_metrics['f1']:.4f}\")\n",
        "    print(f\"  Val   → Loss: {val_loss:.4f}  F1: {val_metrics['f1']:.4f}\")\n",
        "\n",
        "    history_stage3.append({\n",
        "        'epoch':      epoch,\n",
        "        'train_loss': train_loss,\n",
        "        'val_loss':   val_loss,\n",
        "        **{f'train_{k}': v for k, v in train_metrics.items()},\n",
        "        **{f'val_{k}':   v for k, v in val_metrics.items()},\n",
        "    })\n",
        "\n",
        "    if val_metrics['f1'] > best_val_f1_s3:\n",
        "        best_val_f1_s3 = val_metrics['f1']\n",
        "        torch.save({\n",
        "            'epoch':            epoch,\n",
        "            'stage':            3,\n",
        "            'model_state_dict': model.state_dict(),\n",
        "            'val_f1':           best_val_f1_s3,\n",
        "            'config':           CONFIG,\n",
        "            'selective_layers': STAGE3_SELECTIVE_LAYERS,\n",
        "            'keep_ratio':       STAGE3_KEEP_RATIO,\n",
        "        }, stage3_ckpt_path)\n",
        "        print(f\"  ✓ Stage 3 best saved! Val F1: {best_val_f1_s3:.4f}\")\n",
        "\n",
        "    early_stopper_s3(val_metrics['f1'])\n",
        "    if early_stopper_s3.stop:\n",
        "        print(\"\\nStopping Stage 3 early.\")\n",
        "        break\n",
        "\n",
        "history_stage3 = pd.DataFrame(history_stage3)"
      ]
